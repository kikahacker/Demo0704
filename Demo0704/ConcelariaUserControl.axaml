<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1190" d:DesignHeight="180"
             MinHeight="180"
             MinWidth="1190"
             x:Class="Demo0704.ConcelariaUserControl">
  <Border BorderBrush="Black"
          BorderThickness="5"
          Name="Back">
  <Grid ColumnDefinitions="200,*,200" ShowGridLines="False">
	  <Border BorderBrush="Black"
              BorderThickness="2"
              Margin="5 10">
      <Image Name="Picture" ClipToBounds="True" Margin="3"/>
      </Border>
      <Border BorderBrush="Black"
              BorderThickness="2"
              Grid.Column="1"
              Margin="0 10">
      <StackPanel Margin="10">
		  <TextBlock Name="Naming" Text="123" Margin="0 5 0 0" FontSize="17"/>
		  <TextBlock Name="Description" Text="123" Margin="0 5 0 0" FontSize="17"/>
		  <TextBlock Name="Manufacturer" Text="123" Margin="0 5 0 0" FontSize="17"/>
		  <StackPanel Orientation="Horizontal">
			  <TextBlock Name="Price" Text="123" Margin="0 5 5 0" FontSize="17"/>
			  <TextBlock Name="PriceNew" Text="123" Margin="5 5" FontSize="17" IsVisible="False"/>
          </StackPanel>
      </StackPanel>
      </Border>
      <Border BorderBrush="Black"
              BorderThickness="2"
              Margin="10"
              Grid.Column="2">
      <TextBlock Name="Discount" Text="123" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="25" FontWeight="Bold"/>
      </Border>
  </Grid>
  </Border>
</UserControl>
